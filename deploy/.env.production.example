# ──────────────────────────────────────────
# 生产环境变量模板
# ──────────────────────────────────────────
# 使用方法:
#   1. cp .env.production.example .env.production
#   2. 填写实际值（使用 openssl rand -hex 32 生成密钥）
#   3. 确保 .env.production 不被提交到 Git
# ──────────────────────────────────────────

# ── 应用配置 ──
DEBUG=false
LOG_LEVEL=WARNING

# ── API 认证密钥 ──
# 用于 Jenkins CLI / 外部服务调用 API
# 生成: openssl rand -hex 32
RELAY_API_KEY=

# ── 加密密钥（必须 32 字节 hex 编码 = 64 个 hex 字符）──
# 生成: openssl rand -hex 32
AES_ENCRYPTION_KEY=
HMAC_SECRET=
CONFIG_MASTER_KEY=

# ── Session 签名密钥 ──
# 生成: openssl rand -hex 32
SESSION_SECRET=

# ── 钉钉应用配置 ──
# 从钉钉开放平台获取: https://open-dev.dingtalk.com/
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_AGENT_ID=

# ── Jenkins 配置 ──
# Jenkins 服务地址（含协议和端口）
JENKINS_URL=
# API Token: Jenkins → User → Configure → API Token
JENKINS_USERNAME=
JENKINS_API_TOKEN=

# ── 管理员账号 ──
# 密码 hash 生成: python3 -c "from passlib.hash import bcrypt; print(bcrypt.hash('your_password'))"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# ── 域名（Nginx SSL 用）──
DOMAIN_NAME=jd-relay.example.com
